# ========================================
# YieldLab Backend — 本番環境変数テンプレート
# Railway のサービス設定画面に貼り付けてください
# ========================================

# Railway が自動注入する PostgreSQL URL（${{Postgres.DATABASE_URL}} で参照）
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/railway

# フロントエンドのVercel URL（CORS許可）
FRONTEND_URL=https://yieldlab.vercel.app

# 追加CORSオリジン（カンマ区切り）
EXTRA_CORS_ORIGINS=https://yieldlab.dev,https://www.yieldlab.dev

# スクレイパーモード: mock（デフォルト）/ playwright（本番スクレイプ）
SCRAPER_MODE=mock

# 自動承認の閾値（ランク数）
AUTO_APPROVE_THRESHOLD=1
